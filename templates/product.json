        "question_7FMMCE": {
          "type": "question",
          "settings": {
            "title": "Is my payment data safe with you?",
            "text": "<p>All direct payment gateways adhere to the standards set by PCI-DSS as managed by the PCI Security Standards Council, which is a joint effort of brands like Visa, MasterCard, American Express, and Discover.</p>"
          }
        },
        "question_9jrziF": {
          "type": "question",
          "settings": {
            "title": "What do I do if my product is broken during transport?",
            "text": "<p>We strive to package your orders carefully and with appropriate protection to ensure you always an undamaged delivery.</p><p>In the event that the goods arrive at their destination broken or damaged, <strong>we will replace the product at our expense.</strong></p>"
          }
        },
        "question_rpHWJY": {
          "type": "question",
          "settings": {
            "title": "How long does it take to get my products?",
            "text": "<p><strong>Processing time: </strong>We strive for a swift preparation process and orders are typically processed and dispatched within 2-4 business days so that customers can receive their items promptly.</p><p><strong>Free Shipping time:</strong> The timeline below provided is an estimate, and actual shipping times may vary depending on item availability, order volume, and the final destination. </p><ul><li>AU: 5 to 10 business days </li><li>US: 6 to 20 business days </li><li>UK: 6 to 12 business days</li><li>EU: 6 to 12 business days</li><li>Rest of the World: 6 to 20 business days (please inquire at info@hugbel.com for more details) </li></ul><p>In case you need <strong>express delivery</strong>, we can arrange at an additional cost, please contact info@hugbel for the quote with a link to your desired product before placing an order.</p>"
          }
        },
        "question_waYq3U": {
          "type": "question",
          "settings": {
            "title": "Do you offer warranty for your products?",
            "text": "<p>Our warranty provides a 2 year guarantee against manufacturer defects.<br/><br/>The guarantee covers any manufacturing, design, or material defect. </p><p><br/>It does not cover blows, improper use, or other issues that are not attributable to a manufacturer defects.</p><p>All our products are subject to quality control.</p>"
          }
        },
        "question_W8f86E": {
