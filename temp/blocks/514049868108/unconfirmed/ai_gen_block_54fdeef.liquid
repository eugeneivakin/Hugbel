{% doc %}
  @prompt
    сгенеруй секцію з продуктом де відоьражается тільки перша картинка пролукту 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-single-image-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-product-single-image__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-product-single-image__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-product-single-image__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-product-single-image__placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 400px;
  }

  .ai-product-single-image__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-product-single-image__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-product-single-image__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_spacing }}px;
  }

  .ai-product-single-image__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    {% if block.settings.title_alignment == 'center' %}
      text-align: center;
    {% elsif block.settings.title_alignment == 'right' %}
      text-align: right;
    {% else %}
      text-align: left;
    {% endif %}
  }

  .ai-product-single-image__vendor-{{ ai_gen_id }} {
    font-size: {{ block.settings.vendor_size }}px;
    color: {{ block.settings.vendor_color }};
    {% if block.settings.title_alignment == 'center' %}
      text-align: center;
    {% elsif block.settings.title_alignment == 'right' %}
      text-align: right;
    {% else %}
      text-align: left;
    {% endif %}
  }

  .ai-product-single-image__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
    {% if block.settings.title_alignment == 'center' %}
      text-align: center;
    {% elsif block.settings.title_alignment == 'right' %}
      text-align: right;
    {% else %}
      text-align: left;
    {% endif %}
  }

  .ai-product-single-image__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    {% if block.settings.title_alignment == 'center' %}
      text-align: center;
    {% elsif block.settings.title_alignment == 'right' %}
      text-align: right;
    {% else %}
      text-align: left;
    {% endif %}
  }

  .ai-product-single-image__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_size }}px;
    text-align: center;
    transition: background-color 0.3s ease;
    {% if block.settings.title_alignment == 'center' %}
      margin: 0 auto;
    {% elsif block.settings.title_alignment == 'right' %}
      margin-left: auto;
    {% endif %}
  }

  .ai-product-single-image__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-product-single-image-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<product-single-image-{{ ai_gen_id }}
  class="ai-product-single-image-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-product-single-image__container-{{ ai_gen_id }}">
    {% if block.settings.product %}
      {% assign product = block.settings.product %}
      
      <div class="ai-product-single-image__image-wrapper-{{ ai_gen_id }}">
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | image_url: width: 2000 }}"
            alt="{{ product.featured_image.alt | escape }}"
            loading="lazy"
            width="{{ product.featured_image.width }}"
            height="{{ product.featured_image.height }}"
            class="ai-product-single-image__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-product-single-image__placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      {% if block.settings.show_content %}
        <div class="ai-product-single-image__content-{{ ai_gen_id }}">
          {% if block.settings.show_vendor and product.vendor != blank %}
            <div class="ai-product-single-image__vendor-{{ ai_gen_id }}">
              {{ product.vendor }}
            </div>
          {% endif %}

          {% if block.settings.show_title %}
            <h2 class="ai-product-single-image__title-{{ ai_gen_id }}">
              {{ product.title }}
            </h2>
          {% endif %}

          {% if block.settings.show_price %}
            <div class="ai-product-single-image__price-{{ ai_gen_id }}">
              {{ product.price | money }}
            </div>
          {% endif %}

          {% if block.settings.show_description and product.description != blank %}
            <div class="ai-product-single-image__description-{{ ai_gen_id }}">
              {{ product.description | strip_html | truncate: 200 }}
            </div>
          {% endif %}

          {% if block.settings.show_button %}
            <a
              href="{{ product.url }}"
              class="ai-product-single-image__button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% else %}
      <div class="ai-product-single-image__image-wrapper-{{ ai_gen_id }}">
        <div class="ai-product-single-image__placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
          <div class="ai-product-single-image__empty-state-{{ ai_gen_id }}">
            Виберіть продукт для відображення
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</product-single-image-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductSingleImage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('product-single-image-{{ ai_gen_id }}', ProductSingleImage{{ ai_gen_id }});
  })();
</script>

