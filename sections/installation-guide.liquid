<section class="grid-box-section">
  <div class="container">
    <h1>{{ section.settings.section_title }}</h1>
    <div class="grid-box">
      {% for block in section.blocks %}
        <div class="grid-item card-wrapper card card--media">
          {% if block.settings.image %}
            <a  href="{{ block.settings.link }}" >
            <img src="{{ block.settings.image | img_url: 'medium' }}" alt="{{ block.settings.title }}">
            </a>
          {% endif %}
          <h3 class="card-information__text h3">{{ block.settings.title }}</h3>
          <div>{{ block.settings.description }}</div>
          {% if block.settings.link %}
            <a  href="{{ block.settings.link }}" class="grid-link button">Instructions</a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  section.grid-box-section .container {
    max-width: 1600px;
    margin: auto;
}
  .grid-box a.grid-link.button {
    color: #fff;
    min-height: unset;
    padding: 17px 35px;
    min-width: unset;
}
  .grid-box a.grid-link.button:hover {
    text-decoration: none;
}
  .grid-box-section h1 {
    margin-top: 0;
    margin-bottom: 30px;
}
  .grid-box-section {
    text-align: center;
    padding: 60px 15px;
  }
.grid-box {
    display: grid;
    grid-template-columns: auto auto auto;
    gap: 20px;
    margin-top: 20px;
}
.grid-item {
    background: #f9f9f9;
    padding: 20px 30px;
    border-radius: 10px;
}
  .grid-item img {
    max-width: 100%;
    border-radius: 3px;
    transition: .3s;
  }
  .grid-item:hover img {
    transform: scale(1.1);
    transition: .3s;
}
  .grid-link {
    display: inline-block;
    margin-top: 10px;
    color: #005ea0;
    text-decoration: none;
    font-weight: bold;
  }
  .grid-link:hover {
    text-decoration: underline;
  }
  body .grid-item h3 {
    font-size: 28px;
}
  @media only screen and (max-width: 1024px) {
    .grid-box {
      grid-template-columns: auto auto;
    }
  }
  @media only screen and (max-width: 650px) {
    .grid-box {
      grid-template-columns: auto;
    }
    body .grid-item h3 {
    font-size: 22px;
}
  }
</style>


{% schema %}
{
  "name": "Grid Box Section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Our Featured Grid"
    }
  ],
  "blocks": [
    {
      "type": "grid_item",
      "name": "Grid Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Grid Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Enter a description here.</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Grid Box Section",
      "category": "Custom",
      "blocks": [
        {
          "type": "grid_item"
        },
        {
          "type": "grid_item"
        },
        {
          "type": "grid_item"
        }
      ]
    }
  ]
}
{% endschema %}